{
  "name": "movies-for-hackers",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "author": "Scott Reinhart <scottdreinhart@users.noreply.github.com> (https://github.com/scottdreinhart)",
  "packageManager": "pnpm@10.30.3",
  "main": "electron/main.cjs",
  "scripts": {
    "setup:win": "powershell -ExecutionPolicy Bypass -File scripts/platform-swap.ps1",
    "setup:linux": "bash scripts/platform-swap.sh",

    "dev": "vite",
    "dev:win": "pnpm setup:win && vite",
    "dev:linux": "pnpm setup:linux && vite",

    "build": "tsc --noEmit && vite build",
    "build:win": "pnpm setup:win && pnpm build",
    "build:linux": "pnpm setup:linux && pnpm build",

    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "check": "pnpm lint && pnpm format:check",
    "fix": "pnpm lint:fix && pnpm format",
    "validate": "pnpm check && pnpm build",
    "clean": "rimraf dist release android ios .vite",
    "clean:modules": "rimraf node_modules",
    "reinstall": "pnpm clean:modules && pnpm install",
    "prebuild": "pnpm lint",

    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5175 && electron .\"",
    "electron:dev:win": "pnpm setup:win && pnpm electron:dev",
    "electron:build": "pnpm clean && pnpm build && electron-builder",
    "electron:build:win": "pnpm setup:win && pnpm clean && pnpm build && electron-builder --win",
    "electron:build:linux": "pnpm setup:linux && pnpm clean && pnpm build && electron-builder --linux",
    "electron:build:mac": "pnpm clean && pnpm build && electron-builder --mac",
    "electron:build:all": "pnpm clean && pnpm build && electron-builder --win --linux --mac",

    "cap:sync": "pnpm build && npx cap sync",
    "cap:init:android": "npx cap add android",
    "cap:init:ios": "npx cap add ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npx cap run android",
    "cap:run:ios": "npx cap run ios",
    "cap:dev:android": "pnpm cap:sync && pnpm cap:run:android",
    "cap:dev:ios": "pnpm cap:sync && pnpm cap:run:ios",
    "release:web": "pnpm validate",
    "release:desktop": "pnpm validate && electron-builder",
    "release:mobile": "pnpm validate && npx cap sync"
  },
  "build": {
    "appId": "com.scottdreinhart.movies-for-hackers",
    "productName": "Movies for Hackers",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.entertainment"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "electron",
      "electron-winstaller"
    ]
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@tanstack/react-virtual": "^3.13.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "is-fullwidth-code-point": "^5.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.0",
    "wait-on": "^9.0.4"
  }
}
